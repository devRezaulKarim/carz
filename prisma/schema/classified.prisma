model Classified {
    id             Int              @id @default(autoincrement())
    views          Int              @default(0)
    slug           String           @unique
    vrm            String?
    title          String?
    description    String?
    year           Int?
    odoReading     Int              @default(0) @map("odo_reading")
    doors          Int              @default(2)
    seats          Int              @default(5)
    price          BigInt           @default(0)
    makeId         Int              @map("make_id")
    make           Make             @relation(fields: [makeId], references: [id])
    modelId        Int              @map("model_id")
    model          Model            @relation(fields: [modelId], references: [id])
    modelVariantId Int              @map("model_variant_id")
    modelVariant   ModelVariant?    @relation(fields: [modelVariantId], references: [id])
    ulezCompliance ULEZCompliance   @default(EXEMPT) @map("ulez_compliance")
    transmission   Transmission     @default(MANUAL)
    color          Color            @default(BLACK)
    fuelType       FuelType         @default(PETROL) @map("fuel_type")
    bodyType       BodyType         @default(SEDAN) @map("body_type")
    odoUnit        OdoUnit          @default(MILES) @map("odo_unit")
    status         ClassifiedStatus @default(DRAFT)

    currency  CurrencyCode @default(USD)
    images    Image[]
    customers Customer[]
    createdAt DateTime     @default(now()) @map("created_At")
    updatedAt DateTime     @updatedAt @map("updated_At")

    @@index([makeId, modelId], name: "index_make_model")
    @@index([status], name: "index_status")
    @@index([price], name: "index_price")
    @@map("classifieds")
}

enum ClassifiedStatus {
    LIVE
    DRAFT
    SOLD
}

enum CurrencyCode {
    USD
    GBP
    BDT
    INR
}

enum OdoUnit {
    MILES
    KILOMETERS
}

enum BodyType {
    SEDAN
    HATCHBACK
    SUV
    COUPE
    CONVERTIBLE
    WAGON
}

enum FuelType {
    PETROL
    DIESEL
    ELECTRIC
    HYBRID
}

enum ULEZCompliance {
    EXEMPT
    NON_EXEMPT
}

enum Transmission {
    MANUAL
    AUTOMATIC
}

enum Color {
    BLACK
    BLUE
    BROWN
    GOLD
    GREEN
    GREY
    ORANGE
    PINK
    PURPLE
    odoReadingSILVER
    WHITE
    YELLOW
}
